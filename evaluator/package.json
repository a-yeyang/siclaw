{
  "name": "@siclaw/evaluator",
  "version": "0.0.1",
  "private": true,
  "description": "External skill-audit evaluator for siclaw — quantifies skill trigger reliability via fault-inject + chat-trace inspection",
  "type": "module",
  "engines": {
    "node": ">=22.12.0"
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsx src/main.ts",
    "start": "node dist/main.js",
    "test": "vitest run",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@kubernetes/client-node": "^1.4.0",
    "js-yaml": "^4.1.1",
    "mysql2": "^3.22.3"
  },
  "devDependencies": {
    "@types/js-yaml": "^4.0.9",
    "@types/node": "^22.19.8",
    "tsx": "^4.21.0",
    "typescript": "^5.9.0",
    "vitest": "^3.0.0"
  }
}
